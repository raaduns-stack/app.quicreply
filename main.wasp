  entities: [User, Organization, Contact, Campaign, CampaignRecipient, Deal, PipelineStage, PipelineTemplate],
  auth: true
}

action deleteCampaign {
  fn: import { deleteCampaign } from "@src/campaigns/operations",
  entities: [User, Organization, Campaign, CampaignRecipient],
  auth: true
}

action deleteManyCampaigns {

  fn: import { getPaginatedUsers } from "@src/user/operations",
  entities: [User],
  auth: true
}

query getWorkspaceShell {
  fn: import { getWorkspaceShell } from "@src/user/operations",
  entities: [User, Organization],
  auth: true
}


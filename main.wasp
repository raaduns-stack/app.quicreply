  authRequired: true,
  component: import InboxPage from "@src/user/InboxPage"
}

route SettingsRoute { path: "/settings", to: SettingsPage }
page SettingsPage {
  authRequired: true,
  component: import SettingsPage from "@src/user/SettingsPage"
}

route TeamRoute { path: "/team", to: TeamPage }
page TeamPage {
  authRequired: true,
  component: import TeamPage from "@src/user/TeamPage"
}

route PipelineRoute { path: "/pipeline", to: PipelinePage }
page PipelinePage {
  authRequired: true,
  component: import PipelinePage from "@src/user/PipelinePage"
}

page DashboardPipelinePage {
  authRequired: true,
  component: import PipelinePage from "@src/user/PipelinePage"
}

route AccountRoute { path: "/account", to: AccountPage }
page AccountPage {
  authRequired: true,
  component: import Account from "@src/user/AccountPage"
}

route AnalyticsRoute { path: "/analytics", to: AnalyticsPage }
page AnalyticsPage {
  authRequired: true,
  component: import AnalyticsPage from "@src/user/AnalyticsPage"
}


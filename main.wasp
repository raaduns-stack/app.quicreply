  auth: true
}

action completeOfficialApiEmbeddedSignupSession {
  fn: import { completeOfficialApiEmbeddedSignupSession } from "@src/whatsapp/operations",
  entities: [User, Organization],
  auth: true
}

api evolutionWhatsAppWebhook {
  fn: import { evolutionWhatsAppWebhook } from "@src/whatsapp/webhook",
  httpRoute: (POST, "/webhooks/evolution/whatsapp"),
  auth: false
}

api metaWhatsAppWebhook {
  fn: import { metaWhatsAppWebhook } from "@src/whatsapp/webhook",
  middlewareConfigFn: import { metaWebhookMiddlewareConfigFn } from "@src/whatsapp/webhook",
  httpRoute: (ALL, "/webhooks/meta/whatsapp"),
  auth: false
}

api metaWhatsAppWebhookLegacyAlias {
  fn: import { metaWhatsAppWebhook } from "@src/whatsapp/webhook",
  middlewareConfigFn: import { metaWebhookMiddlewareConfigFn } from "@src/whatsapp/webhook",
  httpRoute: (ALL, "/webhook/meta"),
  auth: false
}

api n8nWhatsAppReplyWebhook {
  fn: import { n8nWhatsAppReplyWebhook } from "@src/whatsapp/webhook",
  httpRoute: (POST, "/webhooks/n8n/whatsapp/reply"),
  auth: false
}

api n8nCampaignStatusWebhook {
  fn: import { n8nCampaignStatusWebhook } from "@src/campaigns/webhook",
  httpRoute: (POST, "/webhooks/n8n/campaigns/status"),

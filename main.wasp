  fn: import { updateWorkspaceSettings } from "@src/user/settingsOperations",
  entities: [User, Organization],
  auth: true
}

action runAiSandboxTest {
  fn: import { runAiSandboxTest } from "@src/user/aiTestOperations",
  entities: [User, Organization],
  auth: true
}

action updateIsUserAdminById {
  fn: import { updateIsUserAdminById } from "@src/user/operations",
